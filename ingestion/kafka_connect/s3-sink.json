{
  "name": "retailpulse-s3-sink",
  "config": {
    "connector.class": "io.confluent.connect.s3.S3SinkConnector",
    "tasks.max": "2",

    "topics.regex": "retailpulse\\.(orders|order_items|users|inventory)",

    "s3.region": "us-east-1",
    "s3.bucket.name": "${env:S3_BRONZE_BUCKET}",
    "s3.part.size": "67108864",
    "s3.ssea.name": "aws:kms",

    "storage.class": "io.confluent.connect.s3.storage.S3Storage",
    "format.class": "io.confluent.connect.s3.format.parquet.ParquetFormat",
    "parquet.codec": "snappy",

    "locale": "en_US",
    "timezone": "UTC",
    "flush.size": "10000",
    "rotate.interval.ms": "300000",
    "rotate.schedule.interval.ms": "600000",

    "timestamp.extractor": "RecordField",
    "timestamp.field": "ts_ms",

    "path.format": "'year'=YYYY/'month'=MM/'day'=dd/'hour'=HH",
    "topics.dir": "bronze",
    "directory.delim": "/",
    "file.delim": "+",

    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",

    "errors.tolerance": "all",
    "errors.log.enable": "true",
    "errors.deadletterqueue.topic.name": "retailpulse.s3sink.dlq"
  }
}
